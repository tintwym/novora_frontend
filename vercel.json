{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, must-revalidate" }]
    },
    {
      "source": "/auth/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://novora-backend-56ot.onrender.com/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://novora-backend-56ot.onrender.com/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://novora-backend-56ot.onrender.com/auth/:path*"
    },
    {
      "source": "/actuator/:path*",
      "destination": "https://novora-backend-56ot.onrender.com/actuator/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
